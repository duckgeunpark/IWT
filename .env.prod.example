# ═══════════════════════════════════════════════════════════════
# IWT — 프로덕션 환경변수 (.env.prod)
# 이 파일을 .env.prod 로 복사 후 실제 값 입력
# cp .env.prod.example .env.prod
# ═══════════════════════════════════════════════════════════════

# ── Database (VM 내부 MySQL 컨테이너) ───────────────────────────
# DB_HOST는 docker-compose.prod.yml에서 "mysql"로 자동 설정됨
DB_HOST=mysql
DB_PORT=3306
DB_NAME=iwt_db
DB_USER=iwt_user
DB_PASSWORD=강력한_비밀번호_입력

# ── Auth0 ────────────────────────────────────────────────────────
AUTH0_DOMAIN=duckgeunpark.us.auth0.com
AUTH0_AUDIENCE=https://duckgeunpark.us.auth0.com/api/v2/
AUTH0_ALGORITHMS=RS256

# ── OCI Object Storage (S3 호환 API) ────────────────────────────
# OCI 콘솔 → Identity & Security → Users → 고객 비밀 키 생성
# Namespace: OCI 콘솔 우측 상단 프로필 → Tenancy
OCI_S3_ENDPOINT=https://NAMESPACE.compat.objectstorage.ap-chuncheon-1.oraclecloud.com
OCI_ACCESS_KEY_ID=고객_비밀_키_액세스_키
OCI_SECRET_ACCESS_KEY=고객_비밀_키_비밀_키
OCI_REGION=ap-chuncheon-1
OCI_BUCKET_NAME=iwt-storage

# ── LLM ──────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL_NAME=gemini-3.1-flash-lite-preview
GEMINI_API_KEY=AIzaSy_여기에_입력

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# ── 보안 ──────────────────────────────────────────────────────────
# 랜덤 생성: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=랜덤_64자_이상으로_반드시_변경

# ── 앱 설정 ───────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
# pydantic v2는 JSON 배열 형식 필요
ALLOWED_ORIGINS=["http://OCI_VM_퍼블릭IP","https://도메인.com"]

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LLM=10/minute

# ── 파일 업로드 ───────────────────────────────────────────────────
MAX_FILE_SIZE=10485760

# ── Frontend 빌드 인자 (docker-compose.prod.yml ARG로 전달) ───────
REACT_APP_AUTH0_DOMAIN=duckgeunpark.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=여기에_Auth0_Client_ID
REACT_APP_AUTH0_CALLBACK_URL=http://OCI_VM_퍼블릭IP
REACT_APP_AUTH0_AUDIENCE=https://duckgeunpark.us.auth0.com/api/v2/
REACT_APP_GOOGLE_MAPS_API_KEY=여기에_Google_Maps_API_Key
REACT_APP_API_URL=http://OCI_VM_퍼블릭IP
